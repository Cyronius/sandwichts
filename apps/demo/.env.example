# Copy to .env for live-model mode (the default page). Not needed for ?mock=1.
# Any OpenAI-compatible Chat Completions server works — pick ONE setup:

# --- OpenAI / ChatGPT ---
OPENAI_API_KEY=
SANDWICH_MODEL=gpt-4o-mini
# SANDWICH_BASE_URL defaults to https://api.openai.com/v1

# --- Ollama (local, no key) ---
# SANDWICH_BASE_URL=http://localhost:11434/v1
# SANDWICH_MODEL=llama3.2

# --- LM Studio (local, no key) ---
# SANDWICH_BASE_URL=http://localhost:1234/v1
# SANDWICH_MODEL=your-loaded-model
