{
  "name": "@sandwichts/core",
  "version": "0.1.0",
  "description": "Browser-native CodeAct engine: LLM-generated JavaScript executed in an iframe+worker sandbox with a whitelisted tool bridge.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@ag-ui/client": ">=0.0.47"
  },
  "peerDependenciesMeta": {
    "@ag-ui/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ag-ui/client": "^0.0.47",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
